# Event Producer — environment configuration
# Copy this file to `.env` (or `.env.local`) and fill in values. NEVER commit a
# real `.env*` — it is gitignored. This file documents the live toggles and the
# bits a public-clone reviewer must set.

# ---------------------------------------------------------------------------
# Live Gemini provider server-side seam (P7A)
# ---------------------------------------------------------------------------
# The Gemini SDK is imported lazily and ONLY server-side, and ONLY when BOTH of
# the following are true:
#   1. ENABLE_LIVE_GEMINI is exactly "true"
#   2. a Gemini API key is present (GEMINI_API_KEY or the legacy GOOGLE_API_KEY)
# Otherwise the app runs in honest, deterministic "rule-based fallback" mode
# and records the fallback reason in the agent trace. Frontend clone demos work
# with neither set.

# Toggle the live Gemini path. Default: unset / "false" (use fallback).
# Values other than the exact string "false" are treated as false.
ENABLE_LIVE_GEMINI=false

# Server-side Gemini API key. Only read by the backend — never sent to the
# browser and never via NEXT_PUBLIC_*. Leave blank to use fallback mode.
GEMINI_API_KEY=

# Legacy alias, used only if GEMINI_API_KEY is empty.
GOOGLE_API_KEY=

# Which Gemini model the live provider requests. Uses the google-genai SDK.
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Backend hosting
# ---------------------------------------------------------------------------
# Comma-separated allowed CORS origins for the FastAPI backend.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Base URL the Next.js UI calls for the backend API. Defaults to localhost:8080
# if unset. The frontend talks to the backend — the backend talks to Gemini.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
