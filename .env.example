# Event Producer — environment configuration
# Copy this file to `.env` (or `.env.local`) and fill in values. NEVER commit a
# real `.env*` — it is gitignored. This file documents the live toggles and the
# bits a public-clone reviewer must set.

# ---------------------------------------------------------------------------
# Live model provider server-side seam (P7A/P7F/P7H.5)
# ---------------------------------------------------------------------------
# Live providers are loaded only server-side. Otherwise the app runs in honest,
# deterministic "rule-based fallback" mode and records the fallback reason in
# the agent trace. Frontend clone demos work with none of these set. The
# Settings page writes these same gitignored values in local development and
# includes a Test provider button backed by POST /runtime/model/test.
# Runtime diagnostics include non-secret response-format mode and whether a
# safe schema repair was applied; API keys and full prompts are not returned.

# Toggle the generic live-model path. Default: unset / "false" (use fallback).
ENABLE_LIVE_MODEL=false

# Fail fast instead of silently falling back when live mode is enabled and a
# provider call fails. Default: true. Has no effect when ENABLE_LIVE_MODEL=false.
STRICT_LIVE_MODEL=true

# Per-provider request timeout. Invalid, blank, or non-positive values fall back
# to 12 seconds.
MODEL_REQUEST_TIMEOUT_SECONDS=12

# Conservative cap for provider text output on OpenAI-compatible/Gemini calls.
MODEL_MAX_OUTPUT_TOKENS=900

# Provider: gemini, openrouter, openai_compatible, local, ollama, or lmstudio.
# Gemini remains the default for capstone continuity.
MODEL_PROVIDER=gemini

# Generic model name override for non-Gemini providers.
MODEL_NAME=

# Legacy Gemini toggle. Still supported for older local setups.
ENABLE_LIVE_GEMINI=false

# Server-side Gemini API key. Only read by the backend — never sent to the
# browser and never via NEXT_PUBLIC_*. Leave blank to use fallback mode.
GEMINI_API_KEY=

# Legacy alias, used only if GEMINI_API_KEY is empty.
GOOGLE_API_KEY=

# Which Gemini model the live provider requests. Uses the google-genai SDK.
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter. Uses the OpenAI-compatible chat-completions provider.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Generic OpenAI-compatible endpoint, e.g. OpenAI-compatible hosted gateway,
# LM Studio, Ollama, or a local router. Some LM Studio servers require an API
# token; put that token in OPENAI_COMPATIBLE_API_KEY.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_API_BASE_URL=

# Local defaults are used when MODEL_PROVIDER=local/ollama/lmstudio.
LOCAL_LLM_API_BASE_URL=http://127.0.0.1:11434/v1/chat/completions
LOCAL_LLM_MODEL=qwen2.5-coder:latest

# ---------------------------------------------------------------------------
# Backend hosting
# ---------------------------------------------------------------------------
# Comma-separated allowed CORS origins for the FastAPI backend.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3001,http://127.0.0.1:3002

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Base URL the Next.js UI calls for the backend API. Defaults to localhost:8080
# if unset. The frontend talks to the backend — the backend talks to Gemini.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
